        <!-- Cockpit/sb_sci_fi_fighter_basic | Spacebar Cockpit Emporium [2394666287] -->
<Definition xsi:type="MyObjectBuilder_CockpitDefinition">
      <Id>
        <TypeId>Cockpit</TypeId>
        <SubtypeId>sb_sci_fi_fighter_basic</SubtypeId>
        <!-- Small block passenger seat -->
      </Id>
      <DisplayName>SB Fighter Cockpit Basic</DisplayName>
      <Icon>Textures\sb_sci_fi_fighter_basic.dds</Icon>
      <Description>Description_PassengerSeat</Description>
      <CubeSize>Small</CubeSize>
	   <GuiVisible>true</GuiVisible>
      <BlockTopology>TriangleMesh</BlockTopology>
    <Size x="3" y="3" z="5"/>
      <!--<ModelOffset x="0" y="0" z="1" />-->
      <Model>Models\sb_sci_fi_fighter_basic.mwm</Model>
      <CharacterAnimation>sb_sci_fi_fighter_pose</CharacterAnimation>
      <UsesDeformation>false</UsesDeformation>
            <Components>
        <Component Subtype="Construction" Count="20" />
        <Component Subtype="Motor" Count="1" />
        <Component Subtype="SteelPlate" Count="30" />
        <Component Subtype="MetalGrid" Count="30" />
        <Component Subtype="InteriorPlate" Count="15" />
        <Component Subtype="Display" Count="4" />
        <Component Subtype="Computer" Count="20" />
        <Component Subtype="BulletproofGlass" Count="40" />
        <Component Subtype="SteelPlate" Count="30" />
      </Components>
      <CriticalComponent Subtype="Computer" Index="0" />
      <CriticalComponent Subtype="InteriorPlate" Index="0" />
    <!--<MountPoints>
				<MountPoint Side="Front" StartX="0.0" StartY="0.15" EndX="1.0" EndY="1.64"/>
				<MountPoint Side="Back" StartX="0.0" StartY="0.75" EndX="1.0" EndY="2.25"/>
				<MountPoint Side="Left" StartX="0.0" StartY="0.15" EndX="2.0" EndY="1.64"/>
				<MountPoint Side="Right" StartX="0.0" StartY="0.15" EndX="2.0" EndY="1.64"/>
				<MountPoint Side="Bottom" StartX="0.0" StartY="0.0" EndX="1.0" EndY="2.0"/>
			</MountPoints>-->
			<BuildProgressModels>
				<Model BuildPercentUpperBound="0.33" File="Models\sb_sci_fi_fighter_basic_BS1.mwm"/>
				<Model BuildPercentUpperBound="0.67" File="Models\sb_sci_fi_fighter_basic_BS2.mwm"/>
				<Model BuildPercentUpperBound="1.00" File="Models\sb_sci_fi_fighter_basic_BS3.mwm"/>
			</BuildProgressModels>
	<ScreenAreas>
              <ScreenArea Name="CockpitScreen_01" DisplayName="Left Screen" TextureResolution="854" ScreenWidth="5" ScreenHeight="3" Script="TSS_ArtificialHorizon" />
              <ScreenArea Name="CockpitScreen_02" DisplayName="Middle Top Screen" TextureResolution="854" ScreenWidth="5" ScreenHeight="3" Script="TSS_EnergyHydrogen" />
              <ScreenArea Name="CockpitScreen_03" DisplayName="Middle Bottom Screen" TextureResolution="854" ScreenWidth="5" ScreenHeight="3" Script="TSS_Velocity"/>
            <ScreenArea Name="CockpitScreen_04" DisplayName="Right Screen" TextureResolution="854" ScreenWidth="5" ScreenHeight="3" Script="TSS_Gravity"/>
			   
          </ScreenAreas>

      <VoxelPlacement>
        <StaticMode>
          <PlacementMode>OutsideVoxel</PlacementMode>
          <MaxAllowed>0.2</MaxAllowed>
          <MinAllowed>0</MinAllowed>
        </StaticMode>
        <DynamicMode>
          <PlacementMode>OutsideVoxel</PlacementMode>
          <MaxAllowed>0.2</MaxAllowed>
          <MinAllowed>0</MinAllowed>
        </DynamicMode>
      </VoxelPlacement>
      <BlockPairName>sb_sci_fi_fighter_basic</BlockPairName>
      <MirroringZ>Y</MirroringZ>
      <MirroringY>Z</MirroringY>
      <BuildTimeSeconds>30</BuildTimeSeconds>
     <!-- <EdgeType>Light</EdgeType>-->
      <EnableFirstPerson>true</EnableFirstPerson>
      <EnableShipControl>true</EnableShipControl>
      <EnableBuilderCockpit>true</EnableBuilderCockpit>
      <DeformationRatio>0.2</DeformationRatio>
      <DamageEffectName>Damage_Electrical_Damaged</DamageEffectName>
      <DamagedSound>ParticleElectrical</DamagedSound>
      <PrimarySound>BlockCockpitSm</PrimarySound>
      <OxygenCapacity>60</OxygenCapacity>
      <IsPressurized>true</IsPressurized>
      <GetInSound>ShipSmCockpitIn</GetInSound>
      <GetOutSound>ShipSmCockpitOut</GetOutSound>
      <DestroyEffect>BlockDestroyedExplosion_Small</DestroyEffect>
      <DestroySound>WepSmallWarheadExpl</DestroySound>
      <RaycastOffset>
        <X>-0.0045</X>
        <Y>0.467</Y>
        <Z>0.15</Z>
      </RaycastOffset>
      <PCU>15</PCU>      
    <TargetLockingEnabled>true</TargetLockingEnabled> </Definition>
