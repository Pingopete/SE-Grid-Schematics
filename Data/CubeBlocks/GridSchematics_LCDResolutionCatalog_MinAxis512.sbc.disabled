                <ScreenArea Name="CockpitScreen_01" DisplayName="DisplayName_Screen_Large" TextureResolution="854" ScreenWidth="15" ScreenHeight="9" />
                <ScreenArea Name="CockpitScreen_02" DisplayName="DisplayName_Screen_Keyboard" TextureResolution="1408" ScreenWidth="11" ScreenHeight="4" />
            </ScreenAreas>
