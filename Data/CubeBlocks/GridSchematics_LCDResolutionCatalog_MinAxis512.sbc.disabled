                <MountPoint Side="Top" StartX="0.2" StartY="0.2" EndX="1.6" EndY="0.8" />
                <MountPoint Side="Top" StartX="0.3" StartY="0.8" EndX="0.6" EndY="1.2" />
                <MountPoint Side="Bottom" StartX="0.1" StartY="0.5" EndX="0.8" EndY="2" Default="true" />
